# ── Database ──────────────────────────────────────────────────────────────────
MEMLORD_DB_URL=postgresql+asyncpg://postgres:postgres@postgres/memlord

# ── ONNX model ────────────────────────────────────────────────────────────────
# Directory containing model.onnx and tokenizer.json.
MEMLORD_MODEL_DIR=/app/src/memlord/onnx

# ── Server ────────────────────────────────────────────────────────────────────
MEMLORD_HOST=0.0.0.0
MEMLORD_PORT=8000

# ── Search tuning ─────────────────────────────────────────────────────────────
# MEMLORD_RRF_K=60
# MEMLORD_DEFAULT_LIMIT=10
# MEMLORD_SIM_THRESHOLD=0.7
# MEMLORD_DEDUP_THRESHOLD=0.95

# ── OAuth 2.1 ─────────────────────────────────────────────────────────────────
# MEMLORD_BASE_URL=http://localhost:8000
# MEMLORD_OAUTH_JWT_SECRET=change-me-to-a-long-random-secret

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# MEMLORD_SMTP_HOST=smtp.resend.com
# MEMLORD_SMTP_PORT=587
# MEMLORD_SMTP_USER=resend
# MEMLORD_SMTP_PASSWORD=re_xxxxxxxxxxxx
# MEMLORD_SMTP_FROM=noreply@example.com
# MEMLORD_SMTP_TLS=true

# ── Reverse proxy subpath ─────────────────────────────────────────────────────
# When deploying behind a reverse proxy at a subpath (e.g. example.com/memlord),
# set BOTH base_url and root_path. base_url must end with root_path.
# MEMLORD_BASE_URL=https://example.com/memlord
# MEMLORD_ROOT_PATH=/memlord

# ── Azure SSO ─────────────────────────────────────────────────────────────────
# Set all three to enable Azure AD authentication.
# MEMLORD_AZURE_SSO_ENABLED=true
# MEMLORD_AZURE_CLIENT_ID=<your-azure-app-client-id>
# MEMLORD_AZURE_CLIENT_SECRET=<your-azure-app-client-secret>
# MEMLORD_AZURE_TENANT_ID=<your-azure-tenant-id>
# MEMLORD_AZURE_REDIRECT_URI=https://example.com/memlord/auth/azure/callback
# MEMLORD_AZURE_SCOPE=openid profile email
# MEMLORD_AZURE_LOGIN_BUTTON_TEXT=Sign in with Azure AD
# MEMLORD_AZURE_ALLOWED_EMAIL_DOMAINS=example.com,contoso.com

# ── Login controls ─────────────────────────────────────────────────────────────
# MEMLORD_LOCAL_PASSWORD_LOGIN_ENABLED=true
# MEMLORD_LOCAL_REGISTRATION_ENABLED=true
